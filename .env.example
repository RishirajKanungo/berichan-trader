# Berichan Auto Cross-Transfer - Credentials
# Copy this file to .env and fill in your values

# --- Twitch Credentials ---
# Run setup_auth.py to get these automatically, or fill manually.
# Your Twitch username (lowercase)
TWITCH_USERNAME=your_twitch_username

# OAuth token with scopes: chat:read chat:edit user:manage:whispers
# Format: oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_OAUTH_TOKEN=oauth:your_token_here

# Client ID from dev.twitch.tv/console (create your own app there)
TWITCH_CLIENT_ID=your_client_id_here

# --- Trade Settings ---
# The 8-digit trade code you use in Pokemon Scarlet/Violet
TRADE_CODE=24932000

# The Twitch channel to post Pokemon to
TWITCH_CHANNEL=berichandev

# The bot's Twitch username to whisper the trade code to
# Common names: BerichanBot, Bot_RocketGrunt — check the channel to confirm
BOT_USERNAME=BerichanBot

# --- Timing (seconds) ---
# Delay between each line of the Pokemon block sent to chat
LINE_SEND_DELAY=0.6

# Delay after posting Pokemon before sending the whisper
POST_WHISPER_DELAY=2.0

# Cooldown between trades (120s = 2 minutes, safe for rate limits)
INTER_TRADE_DELAY=120.0

# Max time to wait for "Initializing trade" before giving up (seconds)
TRADE_TIMEOUT=600.0
